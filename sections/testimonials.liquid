<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2></div><div class="three-grid">{% for block in section.blocks %}<figure class="card reveal-on-scroll" {{ block.shopify_attributes }}><blockquote>“{{ block.settings.quote }}”</blockquote><figcaption><strong>{{ block.settings.name }}</strong><br><span class="text-muted">{{ block.settings.meta }}</span></figcaption></figure>{% endfor %}</div></div></section>
{% schema %}{"name": "Testimonials", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Avis clients"}, {"type": "text", "id": "title", "label": "Titre", "default": "Une parole client formulée pour rassurer, convaincre et répondre aux objections fréquentes."}], "blocks": [{"type": "quote", "name": "Avis", "settings": [{"type": "textarea", "id": "quote", "label": "Citation", "default": "Le goût de l’eau a clairement changé et l’installation a pris moins d’une minute."}, {"type": "text", "id": "name", "label": "Nom", "default": "Camille R."}, {"type": "text", "id": "meta", "label": "Métadonnée", "default": "Paris · Filtre robinet digital"}]}], "max_blocks": 6, "presets": [{"name": "Testimonials", "blocks": [{"type": "quote"}, {"type": "quote", "settings": {"quote": "On a arrêté d’acheter des packs. C’est plus pratique et la cuisine reste nette.", "name": "Nicolas & Sarah", "meta": "Lyon · Famille de 4"}}, {"type": "quote", "settings": {"quote": "J’utilise la gourde filtrante tous les jours au bureau. C’est simple, élégant et cohérent avec mon mode de vie.", "name": "Maya T.", "meta": "Bordeaux · Gourde filtrante"}}]}]}
{% endschema %}
