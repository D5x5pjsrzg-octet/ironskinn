<section class="section"><div class="page-width content-grid"><div class="reveal-on-scroll"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p></div><div class="card reveal-on-scroll"><h3>{{ section.settings.card_title }}</h3><ul class="pill-list">{% for block in section.blocks %}<li style="margin-bottom:.85rem;" {{ block.shopify_attributes }}><strong>{{ block.settings.title }}</strong><br><span class="text-muted">{{ block.settings.text }}</span></li>{% endfor %}</ul></div></div></section>
{% schema %}{"name": "Ecology impact", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Impact écologique"}, {"type": "text", "id": "title", "label": "Titre", "default": "Un angle écologique concret, sans tomber dans les promesses vagues."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Le thème explique l’impact par des gestes simples : moins de bouteilles, moins de transport, une consommation d’eau mieux intégrée au quotidien."}, {"type": "text", "id": "card_title", "label": "Titre carte", "default": "Messages clés à mettre en avant"}], "blocks": [{"type": "item", "name": "Point impact", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Réduction visible du plastique"}, {"type": "text", "id": "text", "label": "Texte", "default": "L’argument est facile à comprendre et utile pour la décision d’achat."}]}], "max_blocks": 4, "presets": [{"name": "Ecology impact", "blocks": [{"type": "item"}, {"type": "item", "settings": {"title": "Moins de trajets d’approvisionnement", "text": "Moins de packs à transporter, stocker ou jeter."}}, {"type": "item", "settings": {"title": "Usage durable dans le temps", "text": "Les cartouches structurent l’entretien au lieu d’encourager le jetable."}}]}]}
{% endschema %}
