<section class="section"><div class="page-width card reveal-on-scroll"><span class="kicker">Panier</span><h1>{{ section.settings.title }}</h1>{% if cart.item_count > 0 %}<form action="{{ routes.cart_url }}" method="post">{% for item in cart.items %}<div class="option-card"><div><strong>{{ item.product.title }}</strong><div class="text-muted">{{ item.variant.title }}</div></div><div><input type="number" name="updates[]" value="{{ item.quantity }}" min="0"><div><strong>{{ item.final_line_price | money }}</strong></div></div></div>{% endfor %}<div class="stack-actions"><button class="button button--ghost" type="submit" name="update">Mettre à jour</button><button class="button button--primary" type="submit" name="checkout">Passer au paiement</button></div></form>{% else %}<p class="text-muted">Votre panier est vide pour le moment.</p><a class="button button--primary" href="{{ routes.all_products_collection_url }}">Voir le catalogue</a>{% endif %}</div></section>
{% schema %}{"name": "Main cart items", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Votre sélection HYDRYS"}], "presets": [{"name": "Main cart items"}]}
{% endschema %}
