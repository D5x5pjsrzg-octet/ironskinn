<section class="section section--tight"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2></div><div class="logo-strip">{% for block in section.blocks %}<div class="card" {{ block.shopify_attributes }}><strong>{{ block.settings.name }}</strong><p class="text-muted">{{ block.settings.caption }}</p></div>{% endfor %}</div></div></section>
{% schema %}{"name": "Logo bar", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Réassurance"}, {"type": "text", "id": "title", "label": "Titre", "default": "Pensé pour les foyers qui veulent mieux boire, sans friction."}], "blocks": [{"type": "item", "name": "Élément", "settings": [{"type": "text", "id": "name", "label": "Nom", "default": "Sans BPA"}, {"type": "text", "id": "caption", "label": "Légende", "default": "Matériaux sûrs et durables"}]}], "max_blocks": 4, "presets": [{"name": "Logo bar", "blocks": [{"type": "item"}, {"type": "item", "settings": {"name": "Installation facile", "caption": "Se fixe en quelques secondes"}}, {"type": "item", "settings": {"name": "Filtres longue durée", "caption": "Rythme clair de remplacement"}}, {"type": "item", "settings": {"name": "Support France", "caption": "Accompagnement avant et après achat"}}]}]}
{% endschema %}
