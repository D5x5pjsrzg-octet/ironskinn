<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p></div><div class="card-grid">{% for block in section.blocks %}<article class="card reveal-on-scroll" {{ block.shopify_attributes }}><p class="kicker">{{ block.settings.eyebrow }}</p><h3>{{ block.settings.title }}</h3><p class="text-muted">{{ block.settings.text }}</p><strong>{{ block.settings.price }}</strong><a class="button button--secondary" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a></article>{% endfor %}</div></div></section>
{% schema %}{"name": "Product grid promo", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Gamme produits"}, {"type": "text", "id": "title", "label": "Titre", "default": "Une collection complète pour la maison, le bureau et les déplacements."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Le thème prévoit une montée en gamme naturelle : produit principal, compléments, cartouches et bundles prêts à augmenter le panier moyen."}], "blocks": [{"type": "product_card", "name": "Carte produit", "settings": [{"type": "text", "id": "eyebrow", "label": "Sur-ligne", "default": "Best-seller"}, {"type": "text", "id": "title", "label": "Titre", "default": "Filtre robinet digital"}, {"type": "textarea", "id": "text", "label": "Texte", "default": "La solution premium pour filtrer à la source."}, {"type": "text", "id": "price", "label": "Prix", "default": "À partir de 79 €"}, {"type": "url", "id": "link", "label": "Lien"}, {"type": "text", "id": "link_label", "label": "Label lien", "default": "Découvrir"}]}], "max_blocks": 5, "presets": [{"name": "Product grid promo", "blocks": [{"type": "product_card"}, {"type": "product_card", "settings": {"eyebrow": "Nomade", "title": "Gourde filtrante", "text": "Hydratation plus sereine au bureau, au sport ou en voyage.", "price": "À partir de 34 €"}}, {"type": "product_card", "settings": {"eyebrow": "Maison", "title": "Carafe filtrante", "text": "Une présence élégante sur la table et au frigo.", "price": "À partir de 49 €"}}]}]}
{% endschema %}
