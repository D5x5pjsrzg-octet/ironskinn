{% if section.settings.show_bar %}<div class="announcement-bar"><div class="page-width announcement-bar__inner"><span>{{ section.settings.message }}</span><strong data-announcement-countdown data-duration="{{ section.settings.countdown_days | times: 86400000 }}">2j 00h 00m</strong><a href="{{ section.settings.link }}">{{ section.settings.link_label }}</a></div></div>{% endif %}
{% schema %}{"name":"Announcement bar","settings":[{"type":"checkbox","id":"show_bar","label":"Afficher la barre","default":true},{"type":"text","id":"message","label":"Message","default":"Livraison offerte dès 69 € · Garantie 30 jours · Installation en 30 secondes"},{"type":"range","id":"countdown_days","label":"Durée du compte à rebours (jours)","min":1,"max":10,"step":1,"default":3},{"type":"url","id":"link","label":"Lien"},{"type":"text","id":"link_label","label":"Texte du lien","default":"Découvrir l’offre"}]}
{% endschema %}
