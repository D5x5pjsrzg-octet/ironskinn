<section class="section"><div class="page-width card reveal-on-scroll"><span class="kicker">{{ section.settings.kicker }}</span><h1>{{ collection.title }}</h1><p class="text-muted">{{ collection.description | strip_html | default: section.settings.fallback_text }}</p></div></section>
{% schema %}{"name": "Main collection banner", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Collection"}, {"type": "textarea", "id": "fallback_text", "label": "Texte de secours", "default": "Une collection structurée pour aider la découverte : produit principal, accessoires, cartouches et bundles."}], "presets": [{"name": "Main collection banner"}]}
{% endschema %}
