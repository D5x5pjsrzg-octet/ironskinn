<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2></div><div class="reveal-on-scroll"><table><thead><tr><th>Critère</th><th>HYDRYS</th><th>Bouteilles</th><th>Carafe classique</th></tr></thead><tbody>{% for block in section.blocks %}<tr {{ block.shopify_attributes }}><td><strong>{{ block.settings.criterion }}</strong></td><td>{{ block.settings.hydrys }}</td><td>{{ block.settings.bottles }}</td><td>{{ block.settings.pitcher }}</td></tr>{% endfor %}</tbody></table></div></div></section>
{% schema %}{"name": "Comparison table", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Comparaison"}, {"type": "text", "id": "title", "label": "Titre", "default": "HYDRYS apporte plus de contrôle et moins de contraintes que les alternatives classiques."}], "blocks": [{"type": "row", "name": "Ligne", "settings": [{"type": "text", "id": "criterion", "label": "Critère", "default": "Praticité"}, {"type": "text", "id": "hydrys", "label": "HYDRYS", "default": "Filtration à la demande, à la source"}, {"type": "text", "id": "bottles", "label": "Bouteilles", "default": "Transport et stockage encombrants"}, {"type": "text", "id": "pitcher", "label": "Carafe", "default": "Capacité limitée et attente au remplissage"}]}], "max_blocks": 5, "presets": [{"name": "Comparison table", "blocks": [{"type": "row"}, {"type": "row", "settings": {"criterion": "Impact écologique", "hydrys": "Moins de bouteilles jetables", "bottles": "Déchets plastiques récurrents", "pitcher": "Modéré, mais dépend de l’usage"}}, {"type": "row", "settings": {"criterion": "Expérience premium", "hydrys": "Design moderne + lecture digitale", "bottles": "Aucune intégration dans la cuisine", "pitcher": "Fonctionnel mais plus traditionnel"}}]}]}
{% endschema %}
