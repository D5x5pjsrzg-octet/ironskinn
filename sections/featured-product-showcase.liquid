<section class="section"><div class="page-width content-grid"><div class="card reveal-on-scroll"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p><div class="badge-row"><span class="badge">Écran digital</span><span class="badge">Installation sans outil</span><span class="badge">Design compact</span></div><a class="button button--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div><div class="product-gallery__main reveal-on-scroll"><div class="media-placeholder"></div></div></div></section>
{% schema %}{"name": "Featured product showcase", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Produit phare"}, {"type": "text", "id": "title", "label": "Titre", "default": "Le filtre robinet digital qui rassure, simplifie et valorise votre plan de travail."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Le produit principal HYDRYS combine filtration, modes d’écoulement intelligents et indicateur de cartouche pour une expérience premium pensée pour la vraie vie."}, {"type": "text", "id": "cta_label", "label": "CTA", "default": "Voir la page produit"}, {"type": "url", "id": "cta_link", "label": "Lien"}], "presets": [{"name": "Featured product showcase"}]}
{% endschema %}
