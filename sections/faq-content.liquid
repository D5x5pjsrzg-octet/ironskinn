{% render 'meta-faq', questions: section.blocks %}<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p></div><div class="faq-list">{% for block in section.blocks %}<details class="faq-item reveal-on-scroll" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}><summary>{{ block.settings.question }}</summary><div class="faq-item__content">{{ block.settings.answer }}</div></details>{% endfor %}</div></div></section>
{% schema %}{"name": "FAQ content", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "FAQ"}, {"type": "text", "id": "title", "label": "Titre", "default": "Des réponses claires pour l’utilisateur et pour les moteurs de réponse IA."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Cette section renforce la conversion tout en améliorant la découvrabilité via FAQPage schema et formulation directe des réponses."}], "blocks": [{"type": "faq", "name": "Question", "settings": [{"type": "text", "id": "question", "label": "Question", "default": "Le filtre robinet HYDRYS est-il facile à installer ?"}, {"type": "richtext", "id": "answer", "label": "Réponse", "default": "<p>Oui. Le système est pensé pour être installé rapidement avec les adaptateurs fournis, sans outil complexe.</p>"}]}], "max_blocks": 8, "presets": [{"name": "FAQ content", "blocks": [{"type": "faq"}, {"type": "faq", "settings": {"question": "Quand faut-il changer la cartouche ?", "answer": "<p>La fréquence dépend de votre usage. L’indicateur digital et la documentation aident à garder le bon rythme.</p>"}}, {"type": "faq", "settings": {"question": "Le produit convient-il à une cuisine familiale ?", "answer": "<p>Oui. Il est particulièrement adapté aux foyers qui veulent réduire les bouteilles, gagner du temps et améliorer l’accès à une eau filtrée.</p>"}}]}]}
{% endschema %}
