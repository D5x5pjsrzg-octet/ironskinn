<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p></div><div class="blog-grid">{% for block in section.blocks %}<article class="card reveal-on-scroll" {{ block.shopify_attributes }}><p class="kicker">{{ block.settings.category }}</p><h3>{{ block.settings.title }}</h3><p class="text-muted">{{ block.settings.excerpt }}</p><a class="button button--secondary" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a></article>{% endfor %}</div></div></section>
{% schema %}{"name": "Blog featured", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Blog & guides"}, {"type": "text", "id": "title", "label": "Titre", "default": "Des contenus pensés pour le SEO, les comparatifs et les réponses IA."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Chaque article répond à une vraie question utilisateur, avec une structure claire et exploitable par les moteurs de recherche et les assistants IA."}], "blocks": [{"type": "article", "name": "Article mis en avant", "settings": [{"type": "text", "id": "category", "label": "Catégorie", "default": "Guide"}, {"type": "text", "id": "title", "label": "Titre", "default": "Eau du robinet : comment améliorer goût et praticité au quotidien ?"}, {"type": "textarea", "id": "excerpt", "label": "Extrait", "default": "Un article de fond pour répondre aux objections, comparer les options et orienter vers la bonne solution."}, {"type": "url", "id": "link", "label": "Lien"}, {"type": "text", "id": "link_label", "label": "Texte du lien", "default": "Lire l’article"}]}], "max_blocks": 3, "presets": [{"name": "Blog featured", "blocks": [{"type": "article"}, {"type": "article", "settings": {"category": "Comparatif", "title": "Filtre à eau vs bouteilles : quelle solution choisir ?", "excerpt": "Coût, écologie, logistique et confort d’usage : les critères qui aident à décider rapidement."}}, {"type": "article", "settings": {"category": "Lifestyle", "title": "Pourquoi adopter une gourde filtrante au bureau ou en déplacement ?", "excerpt": "Une réponse simple à l’hydratation nomade, pensée pour les actifs urbains."}}]}]}
{% endschema %}
