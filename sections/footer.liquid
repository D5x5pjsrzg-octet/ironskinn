<footer class="footer"><div class="page-width footer-grid"><div><h3>{{ section.settings.brand_name }}</h3><p>{{ section.settings.tagline }}</p><small>{{ section.settings.subtext }}</small></div><div><h4>Boutique</h4>{% for block in section.blocks %}{% if block.type == 'shop_link' %}<p><a href="{{ block.settings.url }}">{{ block.settings.label }}</a></p>{% endif %}{% endfor %}</div><div><h4>Aide</h4>{% for block in section.blocks %}{% if block.type == 'help_link' %}<p><a href="{{ block.settings.url }}">{{ block.settings.label }}</a></p>{% endif %}{% endfor %}</div><div><h4>Contact</h4><p>{{ section.settings.contact_title }}</p><p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p><p>{{ section.settings.phone }}</p><p>{{ section.settings.hours }}</p></div></div></footer>
{% schema %}{"name":"Footer","settings":[{"type":"text","id":"brand_name","label":"Marque","default":"HYDRYS"},{"type":"text","id":"tagline","label":"Signature","default":"L’eau pure, partout avec vous."},{"type":"textarea","id":"subtext","label":"Texte bas de page","default":"Technologie de filtration premium, pensée pour les cuisines urbaines, les familles actives et les routines durables."},{"type":"text","id":"contact_title","label":"Titre contact","default":"Conseillers HYDRYS"},{"type":"text","id":"email","label":"Email","default":"bonjour@hydrys.fr"},{"type":"text","id":"phone","label":"Téléphone","default":"01 89 71 24 60"},{"type":"text","id":"hours","label":"Horaires","default":"Lun–Ven · 9h–18h"}],"blocks":[{"type":"shop_link","name":"Lien boutique","settings":[{"type":"text","id":"label","label":"Texte","default":"Filtre robinet digital"},{"type":"url","id":"url","label":"URL"}]},{"type":"help_link","name":"Lien aide","settings":[{"type":"text","id":"label","label":"Texte","default":"Livraison & retours"},{"type":"url","id":"url","label":"URL"}]}],"max_blocks":10}
{% endschema %}
