<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2></div><div class="three-grid">{% for block in section.blocks %}<article class="card reveal-on-scroll" {{ block.shopify_attributes }}><p class="kicker">Étape {{ forloop.index }}</p><h3>{{ block.settings.title }}</h3><p class="text-muted">{{ block.settings.text }}</p></article>{% endfor %}</div></div></section>
{% schema %}{"name": "How it works", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Comment ça marche"}, {"type": "text", "id": "title", "label": "Titre", "default": "Une mise en route simple, conçue pour éliminer les freins à l’achat."}], "blocks": [{"type": "step", "name": "Étape", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Fixez le système"}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Choisissez l’adaptateur adapté et vissez le filtre sur votre robinet en quelques secondes."}]}], "max_blocks": 4, "presets": [{"name": "How it works", "blocks": [{"type": "step"}, {"type": "step", "settings": {"title": "Sélectionnez le mode", "text": "Alternez entre eau filtrée, jet classique et mode rinçage selon l’usage."}}, {"type": "step", "settings": {"title": "Remplacez la cartouche au bon moment", "text": "L’indicateur digital aide à garder une filtration régulière sans approximation."}}]}]}
{% endschema %}
