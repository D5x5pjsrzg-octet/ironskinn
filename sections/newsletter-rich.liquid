<section class="section"><div class="page-width card newsletter-bar reveal-on-scroll"><div><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p></div><div>{% form 'customer', class: 'grid' %}<input type="hidden" name="contact[tags]" value="newsletter"><input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required><button class="button button--primary" type="submit">{{ section.settings.button_label }}</button>{% endform %}</div></div></section>
{% schema %}{"name": "Newsletter rich", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Newsletter"}, {"type": "text", "id": "title", "label": "Titre", "default": "Conseils filtration, offres privées et rappels cartouches sans spam."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Une capture email utile pour le CRM : elle prolonge la relation, soutient la rétention et prépare les ventes de recharges."}, {"type": "text", "id": "placeholder", "label": "Placeholder", "default": "Votre adresse email"}, {"type": "text", "id": "button_label", "label": "Bouton", "default": "Je m’inscris"}], "presets": [{"name": "Newsletter rich"}]}
{% endschema %}
