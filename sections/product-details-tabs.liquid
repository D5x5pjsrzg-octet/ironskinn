<section class="section section--tight"><div class="page-width four-grid">{% for block in section.blocks %}<article class="card reveal-on-scroll" {{ block.shopify_attributes }}><h3>{{ block.settings.title }}</h3><p class="text-muted">{{ block.settings.text }}</p></article>{% endfor %}</div></section>
{% schema %}{"name": "Product details tabs", "blocks": [{"type": "detail", "name": "Détail", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Installation"}, {"type": "textarea", "id": "text", "label": "Texte", "default": "Expliquez de façon claire le montage, la compatibilité et l’entretien pour rassurer avant l’achat."}]}], "max_blocks": 4, "presets": [{"name": "Product details tabs", "blocks": [{"type": "detail"}, {"type": "detail", "settings": {"title": "Garanties", "text": "Mettez en avant la période d’essai, la politique retour et la disponibilité du support."}}, {"type": "detail", "settings": {"title": "FAQ express", "text": "Répondez aux questions fréquentes sans forcer le client à chercher ailleurs."}}, {"type": "detail", "settings": {"title": "Cross-sell", "text": "Proposez cartouches, gourde filtrante ou bundle cuisine + mobilité."}}]}]}
{% endschema %}
