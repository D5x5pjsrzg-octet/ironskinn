{% render 'meta-product', product: product %}<section class="section"><div class="page-width product-layout"><div class="reveal-on-scroll"><div class="product-gallery__main"><div class="media-placeholder"></div></div><div class="thumbnail-row"><div class="thumbnail"></div><div class="thumbnail"></div><div class="thumbnail"></div><div class="thumbnail"></div></div></div><div class="product-panel reveal-on-scroll"><span class="kicker">Produit HYDRYS</span><h1>{{ product.title }}</h1><p class="price">{{ product.price | money }}</p><p class="text-muted">{{ section.settings.lead }}</p><div class="badge-row"><span class="badge">Livraison 48h</span><span class="badge">Garantie 30 jours</span><span class="badge">Support France</span></div>{% form 'product', product, class: 'grid' %}{% if product.has_only_default_variant == false %}<div class="option-grid">{% for variant in product.variants %}<label class="option-card"><span><input type="radio" name="id" value="{{ variant.id }}" {% if forloop.first %}checked{% endif %}><strong>{{ variant.title }}</strong><br><span class="text-muted">{{ variant.metafields.custom.short_pitch | default: section.settings.variant_pitch }}</span></span><strong>{{ variant.price | money }}</strong></label>{% endfor %}</div>{% else %}<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">{% endif %}<button type="submit" class="button button--primary">{{ section.settings.cta_label }}</button>{% endform %}<div class="card"><h3>{{ section.settings.benefits_title }}</h3><ul class="pill-list">{% for block in section.blocks %}<li style="margin-bottom:.75rem;" {{ block.shopify_attributes }}><strong>{{ block.settings.title }}</strong><br><span class="text-muted">{{ block.settings.text }}</span></li>{% endfor %}</ul></div><div class="sticky-cart"><button class="button button--primary" type="button" data-scroll-target="form[action*='/cart/add']">{{ section.settings.cta_label }}</button></div></div></div></section>
{% schema %}{"name": "Main product", "settings": [{"type": "textarea", "id": "lead", "label": "Texte d’accroche", "default": "Le produit met les bénéfices en premier : eau plus agréable, usage pratique et design premium immédiatement perceptible."}, {"type": "text", "id": "variant_pitch", "label": "Pitch variante par défaut", "default": "Choisissez la version la plus adaptée à votre cuisine ou votre usage quotidien."}, {"type": "text", "id": "cta_label", "label": "CTA", "default": "Ajouter au panier"}, {"type": "text", "id": "benefits_title", "label": "Titre bénéfices", "default": "Pourquoi ce produit convertit"}], "blocks": [{"type": "benefit", "name": "Bénéfice", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Goût amélioré"}, {"type": "text", "id": "text", "label": "Texte", "default": "Une eau plus nette et plus agréable à consommer au quotidien."}]}], "max_blocks": 5, "presets": [{"name": "Main product", "blocks": [{"type": "benefit"}, {"type": "benefit", "settings": {"title": "Installation rapide", "text": "Lève une objection majeure sur les produits de filtration."}}, {"type": "benefit", "settings": {"title": "Esthétique premium", "text": "Renforce la perception de valeur dès la page produit."}}]}]}
{% endschema %}
