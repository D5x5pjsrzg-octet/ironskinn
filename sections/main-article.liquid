<section class="section"><div class="page-width article-layout"><article class="card reveal-on-scroll"><p class="kicker">{{ article.published_at | date: '%d %B %Y' }}</p><h1>{{ article.title }}</h1><div class="text-muted rte">{{ article.content }}</div><script type="application/ld+json">{"@context":"https://schema.org","@type":"BlogPosting","headline":{{ article.title | json }},"description":{{ article.excerpt_or_content | strip_html | truncate: 180 | json }},"datePublished":{{ article.published_at | date: '%Y-%m-%d' | json }},"author":{"@type":"Person","name":{{ article.author | json }}}}</script></article><aside class="card reveal-on-scroll"><h3>{{ section.settings.sidebar_title }}</h3><p class="text-muted">{{ section.settings.sidebar_text }}</p><a class="button button--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></aside></div></section>
{% schema %}{"name": "Main article", "settings": [{"type": "text", "id": "sidebar_title", "label": "Titre sidebar", "default": "Prolongez la lecture"}, {"type": "textarea", "id": "sidebar_text", "label": "Texte sidebar", "default": "Reliez vos articles à des pages produits, FAQ et pages d’impact pour renforcer le maillage interne."}, {"type": "text", "id": "cta_label", "label": "CTA", "default": "Découvrir HYDRYS"}, {"type": "url", "id": "cta_link", "label": "Lien CTA"}], "presets": [{"name": "Main article"}]}
{% endschema %}
