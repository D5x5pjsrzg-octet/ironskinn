<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">Blog HYDRYS</span><h1>{{ blog.title }}</h1><p class="text-muted">{{ section.settings.intro }}</p></div><div class="blog-grid">{% for article in blog.articles %}<article class="card reveal-on-scroll"><p class="kicker">{{ article.published_at | date: '%d %B %Y' }}</p><h3><a href="{{ article.url }}">{{ article.title }}</a></h3><p class="text-muted">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</p><a class="button button--secondary" href="{{ article.url }}">Lire l’article</a></article>{% else %}<div class="card"><p>Ajoutez des articles pour enrichir la stratégie SEO et la découvrabilité IA.</p></div>{% endfor %}</div></div></section>
{% schema %}{"name": "Main blog", "settings": [{"type": "textarea", "id": "intro", "label": "Introduction", "default": "Guides, comparatifs, conseils d’entretien et réponses aux questions fréquentes autour de l’eau filtrée."}], "presets": [{"name": "Main blog"}]}
{% endschema %}
