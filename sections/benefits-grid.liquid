<section class="section"><div class="page-width"><div class="section__header"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2></div><div class="four-grid">{% for block in section.blocks %}<article class="card reveal-on-scroll" {{ block.shopify_attributes }}><h3>{{ block.settings.title }}</h3><p class="text-muted">{{ block.settings.text }}</p></article>{% endfor %}</div></div></section>
{% schema %}{"name": "Benefits grid", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Bénéfices"}, {"type": "text", "id": "title", "label": "Titre", "default": "Pourquoi HYDRYS améliore le quotidien dès la première semaine."}], "blocks": [{"type": "benefit", "name": "Bénéfice", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Boire plus facilement"}, {"type": "text", "id": "text", "label": "Texte", "default": "Une eau plus agréable à boire encourage une meilleure hydratation."}]}], "max_blocks": 4, "presets": [{"name": "Benefits grid", "blocks": [{"type": "benefit"}, {"type": "benefit", "settings": {"title": "Moins de plastique", "text": "Réduit les achats récurrents de bouteilles à usage unique."}}, {"type": "benefit", "settings": {"title": "Cuisine valorisée", "text": "Le design premium s’intègre dans un intérieur contemporain."}}, {"type": "benefit", "settings": {"title": "Budget mieux maîtrisé", "text": "Le coût d’usage est plus clair qu’un achat fréquent de packs d’eau."}}]}]}
{% endschema %}
