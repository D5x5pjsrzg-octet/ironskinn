<div class="header-shell"><div class="page-width header"><a href="{{ routes.root_url }}" class="header__brand"><span class="header__logo-mark" aria-hidden="true"></span><span>{{ section.settings.brand_name }}</span></a><nav class="header__nav" aria-label="Navigation principale">{% for block in section.blocks %}{% if block.type == 'link' %}<a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>{% endif %}{% endfor %}</nav><div class="header__actions"><a class="button button--ghost" href="{{ routes.search_url }}">Recherche</a><a class="button button--primary" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a></div></div></div>
{% schema %}{"name":"Header","settings":[{"type":"text","id":"brand_name","label":"Nom affiché","default":"HYDRYS"},{"type":"text","id":"cta_label","label":"CTA","default":"Voir la gamme"},{"type":"url","id":"cta_link","label":"Lien du CTA"}],"blocks":[{"type":"link","name":"Lien","settings":[{"type":"text","id":"label","label":"Libellé","default":"Produits"},{"type":"url","id":"url","label":"URL"}]}],"max_blocks":6}
{% endschema %}
