<section class="section"><div class="page-width"><div class="card reveal-on-scroll"><h1>{{ section.settings.title }}</h1>{% if search.performed %}<p class="text-muted">{{ search.results_count }} résultat(s) pour “{{ search.terms }}”.</p>{% endif %}<form action="{{ routes.search_url }}" method="get" class="grid"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.placeholder }}"><button class="button button--primary" type="submit">{{ section.settings.button_label }}</button></form></div>{% if search.performed %}<div class="card-grid" style="margin-top:1rem;">{% for item in search.results %}<article class="card reveal-on-scroll"><h3><a href="{{ item.url }}">{{ item.title }}</a></h3><p class="text-muted">{{ item.content | strip_html | truncate: 140 }}</p></article>{% endfor %}</div>{% endif %}</div></section>
{% schema %}{"name": "Main search", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Rechercher dans HYDRYS"}, {"type": "text", "id": "placeholder", "label": "Placeholder", "default": "Produit, guide, FAQ…"}, {"type": "text", "id": "button_label", "label": "Libellé bouton", "default": "Rechercher"}], "presets": [{"name": "Main search"}]}
{% endschema %}
