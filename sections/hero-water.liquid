<section class="section hero"><div class="page-width hero__layout"><div class="hero__copy reveal-on-scroll"><span class="kicker">{{ section.settings.kicker }}</span><h1>{{ section.settings.title }}</h1><p class="text-muted">{{ section.settings.text }}</p><div class="hero__actions"><a class="button button--primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="button button--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div><div class="hero__proofs">{% for block in section.blocks %}<div class="proof-chip" {{ block.shopify_attributes }}><strong>{{ block.settings.title }}</strong><div class="text-muted">{{ block.settings.text }}</div></div>{% endfor %}</div></div><div class="hero__visual reveal-on-scroll"><div class="device-card"><p><strong>{{ section.settings.visual_badge }}</strong></p><h3>{{ section.settings.visual_title }}</h3><p>{{ section.settings.visual_text }}</p><div class="metric-row"><div class="metric-box"><strong>99%</strong><br>Réduction du goût chloré</div><div class="metric-box"><strong>30 s</strong><br>Installation sans outil</div><div class="metric-box"><strong>3 modes</strong><br>Jet, douche, filtration</div></div></div></div></div></section>
{% schema %}{"name": "Hero water", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Filtration d’eau moderne · Design premium"}, {"type": "textarea", "id": "title", "label": "Titre", "default": "L’eau pure, partout avec vous."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "HYDRYS transforme votre eau du robinet en une expérience plus pure, plus pratique et plus responsable, sans sacrifier le style de votre cuisine ou votre mobilité."}, {"type": "text", "id": "primary_label", "label": "CTA principal", "default": "Découvrir le filtre robinet"}, {"type": "url", "id": "primary_link", "label": "Lien CTA principal"}, {"type": "text", "id": "secondary_label", "label": "CTA secondaire", "default": "Comparer les solutions"}, {"type": "url", "id": "secondary_link", "label": "Lien CTA secondaire"}, {"type": "text", "id": "visual_badge", "label": "Badge visuel", "default": "Nouveau · Filtre robinet digital"}, {"type": "text", "id": "visual_title", "label": "Titre visuel", "default": "Une filtration visible, élégante et rassurante."}, {"type": "textarea", "id": "visual_text", "label": "Texte visuel", "default": "Écran digital, changement de cartouche simplifié, silhouette fine et finition bleu glacier : tout est pensé pour donner confiance dès la première utilisation."}], "blocks": [{"type": "proof", "name": "Preuve", "settings": [{"type": "text", "id": "title", "label": "Titre", "default": "Livraison 48h"}, {"type": "text", "id": "text", "label": "Texte", "default": "Expédition rapide depuis la France"}]}], "max_blocks": 3, "presets": [{"name": "Hero water", "blocks": [{"type": "proof"}, {"type": "proof", "settings": {"title": "Garantie 30 jours", "text": "Essai serein à la maison"}}, {"type": "proof", "settings": {"title": "Économie plastique", "text": "Réduit les bouteilles jetables"}}]}]}
{% endschema %}
