<section class="section"><div class="page-width content-grid"><div class="reveal-on-scroll"><span class="kicker">{{ section.settings.kicker }}</span><h2>{{ section.settings.title }}</h2><p class="text-muted">{{ section.settings.text }}</p><ul class="icon-list">{% for block in section.blocks %}<li class="card" {{ block.shopify_attributes }}><strong>{{ block.settings.problem }}</strong><br><span class="text-muted">{{ block.settings.solution }}</span></li>{% endfor %}</ul></div><div class="card reveal-on-scroll"><h3>{{ section.settings.panel_title }}</h3><p>{{ section.settings.panel_text }}</p><div class="badge-row"><span class="badge">Goût amélioré</span><span class="badge">Moins de déchets</span><span class="badge">Routine simplifiée</span></div><p class="text-muted">{{ section.settings.panel_note }}</p></div></div></section>
{% schema %}{"name": "Problem solution", "settings": [{"type": "text", "id": "kicker", "label": "Kicker", "default": "Problème → solution"}, {"type": "text", "id": "title", "label": "Titre", "default": "Fini les packs d’eau lourds, le plastique jetable et le goût qui décourage."}, {"type": "textarea", "id": "text", "label": "Texte", "default": "HYDRYS répond à trois irritants majeurs : la logistique des bouteilles, le doute sur la qualité perçue de l’eau et le manque de praticité au quotidien."}, {"type": "text", "id": "panel_title", "label": "Titre panneau", "default": "Pourquoi ça convertit ?"}, {"type": "textarea", "id": "panel_text", "label": "Texte panneau", "default": "Le parcours met les bénéfices en premier : eau plus agréable, geste écologique immédiat et design qui s’intègre naturellement dans une cuisine premium."}, {"type": "textarea", "id": "panel_note", "label": "Note panneau", "default": "Cette structure aide aussi les moteurs IA : problèmes, réponses, bénéfices et preuves sont formulés de façon explicite et scannable."}], "blocks": [{"type": "item", "name": "Point", "settings": [{"type": "text", "id": "problem", "label": "Problème", "default": "Porter des packs d’eau devient vite pénible."}, {"type": "text", "id": "solution", "label": "Solution", "default": "Le filtre robinet HYDRYS apporte une eau filtrée à la demande, sans stockage encombrant."}]}], "max_blocks": 4, "presets": [{"name": "Problem solution", "blocks": [{"type": "item"}, {"type": "item", "settings": {"problem": "Le goût ou l’odeur du robinet freinent la consommation.", "solution": "La filtration aide à retrouver une eau plus neutre et plus agréable à boire."}}, {"type": "item", "settings": {"problem": "Les bouteilles plastiques sont coûteuses et peu pratiques.", "solution": "Les cartouches et accessoires HYDRYS réduisent la dépendance aux formats jetables."}}]}]}
{% endschema %}
