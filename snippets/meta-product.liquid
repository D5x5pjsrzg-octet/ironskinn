{%- if product != blank -%}<script type="application/ld+json">{"@context":"https://schema.org","@type":"Product","name":{{ product.title | json }},"description":{{ product.description | strip_html | json }},"brand":{"@type":"Brand","name":{{ shop.name | json }}},"sku":{{ product.selected_or_first_available_variant.sku | json }},"offers":{"@type":"Offer","priceCurrency":{{ cart.currency.iso_code | default: shop.currency | json }},"price":{{ product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '.' | json }},"availability":"https://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}","url":{{ shop.url | append: product.url | json }}}}</script>{%- endif -%}
