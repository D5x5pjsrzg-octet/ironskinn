<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0b3c91">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}<link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 48, height: 48 }}">{%- endif -%}
    <title>{{ page_title }}{%- if current_tags %} – {{ 'general.meta.tags' | t: tags: current_tags | escape }}{% endif -%}{%- if current_page != 1 %} – {{ 'general.meta.page' | t: page: current_page }}{% endif -%}{%- unless page_title contains shop.name %} – {{ shop.name }}{% endunless -%}</title>
    {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
    <script>document.documentElement.classList.remove('no-js');document.documentElement.classList.add('js');</script>
  </head>
  <body class="template-{{ template.name | handle }}">
    <a class="skip-link visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>
    {% section 'announcement-bar' %}
    {% section 'header' %}
    <main id="MainContent" class="site-main" role="main" tabindex="-1">{{ content_for_layout }}</main>
    {% section 'footer' %}
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":{{ shop.name | json }},"url":{{ shop.url | json }},"logo":{% if settings.logo != blank %}{{ settings.logo | image_url: width: 320 | prepend: 'https:' | json }}{% else %}{{ shop.url | json }}{% endif %}}</script>
  </body>
</html>
